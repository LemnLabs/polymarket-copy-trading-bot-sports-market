# ==============================================
# POLYMARKET INSTITUTIONAL COPY TRADING SUITE
# ==============================================
# Configuration for High-Frequency Copy Trading
# Target Profile: Parz1vaI (Whale/Smart Money)
# ==============================================

# --- TARGET ACQUISITION ---
# The wallet address of the high-net-worth trader to replicate.
# Currently targeting: Parz1vaI
USER_ADDRESS=0xB10047d6a254B2EbB306D7a7D13Bf59171AB6461

# --- CAPITAL EXECUTION WALLET ---
# Your Proxy/Safe wallet address for trade execution.
# Ensure sufficient USDC liquidity for position sizing.
PROXY_WALLET=0xYourInstitutionalWallet

# Private Key for the EOA controlling the Proxy Wallet.
# SECURITY WARNING: Keep this offline or in a secure vault when not in use.
PRIVATE_KEY=your_secure_private_key

# --- MARKET INFRASTRUCTURE ---
# Polymarket CLOB (Central Limit Order Book) Endpoints
CLOB_HTTP_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob-ws.polymarket.com

# --- DATA PERSISTENCE ---
# MongoDB Connection URI for trade history and analytics.
MONGO_URI=mongodb://localhost:27017/polymarket_institutional

# --- BLOCKCHAIN NETWORK ---
# High-performance Polygon RPC Endpoint.
# Recommended: Use a private/dedicated RPC for lowest latency (e.g., Alchemy, Infura).
RPC_URL=https://polygon-rpc.com

# USDC Contract Address (Polygon PoS)
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# --- ALGORITHMIC STRATEGY ---
# Polling interval in seconds (Lower = higher frequency/lower latency).
# Recommended: 0.5 or 1 for competitive execution.
FETCH_INTERVAL=1

# Trade Validity Window (Hours).
# Prevents execution of stale signals.
TOO_OLD_TIMESTAMP=24

# Execution Resilience.
# Maximum retry attempts for failed fill-or-kill orders.
RETRY_LIMIT=3
